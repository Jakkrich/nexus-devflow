# PRP Framework - gitignore

# ------------------------------
# 1. WORKSPACES (Logs & Trash)
# ------------------------------
# Logs & Status Files - Always Ignore
.workspaces/logs/
.workspaces/temp/
.workspaces/worktrees/
.workspaces/.uv-cache/
.workspaces-status
.workspaces/specs/*
*.log

# Security & Secrets - CRITICAL IGNORE!
.security-key
.workspaces-security.json

# ------------------------------
# 2. ARTIFACTS (IGNORED BUT KEEP STRUCTURE)
# ------------------------------
# .workspaces/issues/*
# !.workspaces/issues/.gitkeep
# .workspaces/specs/*
# !.workspaces/specs/.gitkeep

# ------------------------------
# 3. BACKEND & TOOLS
# ------------------------------
# Python Virtual Environments
venv/
.venv/
env/

# Python Cache & Bytecode
__pycache__/
*.pyc
*.pyo
*.pyd

# Node.js Dependencies (Future Proofing)
node_modules/
npm-debug.log
yarn-debug.log
yarn-error.log

# Graphify generated knowledge graph
graphify-out/

# ------------------------------
# 4. IDE / EDITOR SETTINGS
# ------------------------------
# VS Code (Optional: Adjust based on team policy)
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# ------------------------------
# 5. OS Generated Files
# ------------------------------
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# ------------------------------
# 6. Documentation & Notes
# ------------------------------
# Keep folder structure but ignore content inside sensitive/messy notes
Nexus-DevFlow/_notes/*
!Nexus-DevFlow/_notes/.gitkeep

# ------------------------------
# 7. Environment Variables
# ------------------------------
**.env

# ------------------------------
# 8. Template HTML
# ------------------------------
template-html/*

# .workspaces/roadmaps_.json

