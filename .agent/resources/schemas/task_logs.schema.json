{
  "type": "object",
  "required": ["schema_version", "spec_id", "created_at", "updated_at", "planning", "coding", "validation", "events"],
  "properties": {
    "schema_version": { "type": "string" },
    "spec_id": { "type": "string" },
    "created_at": { "type": "string" },
    "updated_at": { "type": "string" },
    "planning": { "$ref": "#/$defs/phase" },
    "coding": { "$ref": "#/$defs/phase" },
    "validation": { "$ref": "#/$defs/phase" },
    "events": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["timestamp", "actor", "event", "phase", "ref", "message", "metadata"],
        "properties": {
          "timestamp": { "type": "string" },
          "actor": { "type": "string" },
          "event": { "type": "string" },
          "phase": { "type": "string" },
          "ref": { "type": ["string", "null"] },
          "message": { "type": "string" },
          "metadata": { "type": "object" }
        }
      }
    }
  },
  "$defs": {
    "phase": {
      "type": "object",
      "required": ["status", "started_at", "completed_at", "logs"],
      "properties": {
        "status": { "type": "string", "enum": ["pending", "active", "in_progress", "completed", "failed"] },
        "started_at": { "type": ["string", "null"] },
        "completed_at": { "type": ["string", "null"] },
        "logs": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
