{
  "type": "object",
  "required": ["schema_version", "feature", "description", "workflow_type", "complexity_assessment", "status", "planStatus", "xstateState", "created_at", "updated_at", "phases", "summary"],
  "properties": {
    "schema_version": { "type": "string" },
    "feature": { "type": "string" },
    "description": { "type": "string" },
    "workflow_type": { "type": "string" },
    "status": { "type": "string", "enum": ["backlog", "queue", "planning", "in_progress", "ai_review", "human_review", "done", "error"] },
    "planStatus": { "type": "string", "enum": ["pending", "planning", "approved", "review", "rejected", "done"] },
    "xstateState": { "type": "string", "enum": ["backlog", "planning", "coding", "validation", "qa_review", "human_review", "done"] },
    "created_at": { "type": "string" },
    "updated_at": { "type": "string" },
    "complexity_assessment": {
      "type": "object",
      "required": ["level", "approach"],
      "properties": {
        "level": { "type": "string" },
        "approach": { "type": "string" }
      }
    },
    "phases": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "type", "depends_on", "subtasks"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "type": { "type": "string" },
          "depends_on": { "type": "array", "items": { "type": "string" } },
          "subtasks": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["id", "title", "description", "service", "files_to_modify", "files_to_create", "patterns_from", "verification", "status"],
              "properties": {
                "id": { "type": "string" },
                "title": { "type": "string" },
                "description": { "type": "string" },
                "service": { "type": "string" },
                "files_to_modify": { "type": "array", "items": { "type": "string" } },
                "files_to_create": { "type": "array", "items": { "type": "string" } },
                "patterns_from": { "type": "array", "items": { "type": "string" } },
                "verification": {
                  "type": "object",
                  "required": ["type", "command", "expected"],
                  "properties": {
                    "type": { "type": "string" },
                    "command": { "type": "string" },
                    "expected": { "type": "string" }
                  }
                },
                "status": { "type": "string", "enum": ["pending", "in_progress", "completed", "failed", "done"] }
              }
            }
          }
        }
      }
    },
    "summary": { "type": "object" }
  }
}
